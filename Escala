#include <stdio.h>

int main(){
    
    int A, B, C, D, E, F, G, H, I, J;
    int SOMA;
    printf("Ola gumelpa!! coloca aqui os valores das respostas separados por espacos: ");
    scanf("%d %d %d %d %d %d %d %d %d %d", &A, &B, &C, &D, &E, &F, &G, &H, &I, &J);

    SOMA = A + B + C + D + E + F + G + H + I + J;

    if (SOMA <= 15 ) { 
        printf("%d: Autoestima baixa\n", SOMA);
        
    } else if (SOMA > 25) { 
        printf("%d: Autoestima alta\n", SOMA);
    }
    else {
        printf("%d: Autoestima média\n", SOMA);
    }
    return 0;
    
    }
